<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="WARN">

    <Appenders>

        <!-- Console logs -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger - %msg%n"/>
        </Console>

        <!-- ✅ Dynamic log per test -->
        <Routing name="RoutingAppender">

            <!-- Use testName from ThreadContext -->
            <Routes pattern="$${ctx:testName}">

                <Route>
                    <File name="FileLogger"
                          fileName="logs/${ctx:testName}.log">

                        <PatternLayout
                                pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger - %msg%n"/>

                    </File>
                </Route>

            </Routes>

        </Routing>

    </Appenders>

    <Loggers>

        <Root level="info">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="RoutingAppender"/>
        </Root>

    </Loggers>

</Configuration>